import pandas as pd

input_file = "CLA-Migration/Scripts/wix_articles_scraped_sample.csv"
output_file = "CLA-Migration/Scripts/wix_articles_supabase_clean.csv"

df = pd.read_csv(input_file, engine="python", on_bad_lines="skip")

required_columns = [
    "title",
    "slug",
    "old_url",
    "content",
    "author",
    "published_at",
    "cover_image_url",
    "status",
    "source",
]

df = df[required_columns]

df = df[df["title"].notna()]
df = df[df["content"].notna()]
df = df[df["content"].astype(str).str.strip() != ""]

df.to_csv(
    output_file,
    index=False,
    encoding="utf-8",
    quoting=1
)

print(f"Clean CSV saved to: {output_file}")
print(f"Rows: {len(df)}")
